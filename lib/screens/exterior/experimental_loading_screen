import 'package:flutter/material.dart';
import 'dart:io';
import 'dart:async';
import 'package:http/http.dart' as http;
import 'package:path_provider/path_provider.dart';
import '../../services/helper/image_compression_service.dart';
import '../../services/helper/temp_file_upload_service.dart';
import 'result_screen.dart';
import '../../services/kieUse/exterior_service.dart';
import '../../navigation/app_navigator.dart';

class ExperimentalLoadingScreen extends StatefulWidget {
  final File uploadedImage;
  final String? preUploadedUrl;
  final String buildingType;
  final String styleName;
  final String? colorPalette;

  const ExperimentalLoadingScreen({
    super.key,
    required this.uploadedImage,
    this.preUploadedUrl,
    required this.buildingType,
    required this.styleName,
    this.colorPalette,
  });

  @override
  State<ExperimentalLoadingScreen> createState() =>
      _ExperimentalLoadingScreenState();
}

class _ExperimentalLoadingScreenState extends State<ExperimentalLoadingScreen> {
  String _statusMessage = 'Initializing...';
  String? _taskId;

  @override
  void initState() {
    super.initState();
    _createTask();
  }

  Future<void> _createTask() async {
    try {
      if (!mounted) return;
      String? userImageUrl = widget.preUploadedUrl;
      if (userImageUrl == null || userImageUrl.isEmpty) {
        setState(() => _statusMessage = 'Preparing your image...');
        final compressedImage = await ImageCompressionService.compressImage(widget.uploadedImage);
        if (!mounted) return;
        setState(() => _statusMessage = 'Uploading your image...');
        userImageUrl = await TempFileUploadService.uploadImage(compressedImage);
        try {
          if (compressedImage.path != widget.uploadedImage.path) {
            await compressedImage.delete();
          }
        } catch (e) {}
        if (userImageUrl == null || userImageUrl.isEmpty) throw Exception('Upload failed');
      }

      if (!mounted) return;
      setState(() => _statusMessage = 'Creating your design (Experimental Mode)...');

      final taskId = await ExteriorService.createExteriorTask(
        userImageUrl: userImageUrl,
        styleReferenceUrl: null,
        styleName: widget.styleName,
        buildingType: widget.buildingType,
        colorPalette: widget.colorPalette,
      );

      if (taskId == null) throw Exception('Generation failed to start');

      if (!mounted) return;
      setState(() {
        _taskId = taskId;
        _statusMessage = 'AI is Rendering (Experimental)...';
      });

      _runPolling();
    } catch (e) {
      if (mounted) _showError(e.toString());
    }
  }

  void _runPolling() async {
    if (_taskId == null || !mounted) return;

    try {
      final finalImageUrl = await ExteriorService.pollAndSaveResult(
        taskId: _taskId!,
      );

      if (finalImageUrl != null && mounted) {
        setState(() => _statusMessage = 'Design complete! Finalizing...');
        
        final appDir = await getApplicationDocumentsDirectory();
        final timestamp = DateTime.now().millisecondsSinceEpoch;
        final originalPath = '${appDir.path}/original_$timestamp.jpg';
        await widget.uploadedImage.copy(originalPath);

        final generatedPath = '${appDir.path}/generated_$timestamp.jpg';
        final response = await http.get(Uri.parse(finalImageUrl));
        if (response.statusCode == 200) {
          final file = File(generatedPath);
          await file.writeAsBytes(response.bodyBytes);

          if (mounted) {
            AppNavigator.pushReplacement(
              context,
              ResultScreen(
                originalImage: File(originalPath),
                generatedImage: file,
                buildingType: widget.buildingType,
                styleName: '${widget.styleName} (Experimental)',
                colorPalette: widget.colorPalette,
                creationId: timestamp.toString(),
              ),
            );
          }
        }
      } else {
        if (mounted) _showError('Generation failed or timed out.');
      }
    } catch (e) {
      if (mounted) _showError('Error: $e');
    }
  }

  void _showError(String message) {
    if (mounted) {
      ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text(message)));
      Navigator.pop(context);
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.white,
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
              decoration: BoxDecoration(color: Colors.purple[50], borderRadius: BorderRadius.circular(20), border: Border.all(color: Colors.purple[200]!)),
              child: Row(
                mainAxisSize: MainAxisSize.min,
                children: [
                  Icon(Icons.science, color: Colors.purple[700], size: 20),
                  const SizedBox(width: 8),
                  Text('Experimental Mode', style: TextStyle(color: Colors.purple[700], fontWeight: FontWeight.bold, fontSize: 14)),
                ],
              ),
            ),
            const SizedBox(height: 30),
            SizedBox(width: 80, height: 80, child: CircularProgressIndicator(strokeWidth: 6, valueColor: AlwaysStoppedAnimation<Color>(Colors.purple[400]!))),
            const SizedBox(height: 40),
            Padding(padding: const EdgeInsets.symmetric(horizontal: 40), child: Text(_statusMessage, textAlign: TextAlign.center, style: const TextStyle(fontSize: 16, fontWeight: FontWeight.w500))),
            const SizedBox(height: 20),
            Text("Single-Image Approach\nBetter Structure Preservation", textAlign: TextAlign.center, style: TextStyle(fontSize: 12, color: Colors.purple[600], fontWeight: FontWeight.w500)),
          ],
        ),
      ),
    );
  }
}
