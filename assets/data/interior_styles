  {
    "example_image": "https://bwbopiabddpxhacfscvq.supabase.co/storage/v1/object/public/uploads/home_styles/natural-boho-chic.avif",
    "type": "interior",
    "template_id": "interior0006",
    "style_name": "Natural Boho Chic Style",
